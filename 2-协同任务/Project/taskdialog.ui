    border-radius: 3px;
    color: #c8e8ff;
    padding: 4px 8px;
    font-size: 11px;
    height: 26px;
}

QLineEdit:focus, QComboBox:focus {
    border-color: #00cfff;
    box-shadow: 0 0 8px rgba(0,200,255,0.2);
}

QPushButton {
    height: 28px;
    padding: 0 20px;
    background: rgba(0,140,220,0.2);
    border: 1px solid rgba(0,160,255,0.35);
    border-radius: 3px;
    color: #c8e8ff;
    font-size: 12px;
}

QPushButton:hover {
    background: rgba(0,160,255,0.38);
    color: #e8f4ff;
    border-color: rgba(0,200,255,0.6);
}

QPushButton#okButton {
    background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0,
                                stop:0 rgba(0,150,255,0.4),
                                stop:1 rgba(0,100,200,0.5));
    border-color: #0af;
    color: #e8f4ff;
}

QPushButton#okButton:hover {
    box-shadow: 0 0 12px rgba(0,200,255,0.4);
}</string>
