}

QTabWidget::pane {
    border: 1px solid rgba(0,160,255,0.35);
    background-color: rgba(8,24,48,0.92);
    border-radius: 4px;
}

QTabBar::tab {
    padding: 8px 18px;
    color: #8ab8d8;
    border-right: 1px solid rgba(0,140,220,0.2);
}

QTabBar::tab:hover {
    color: #00cfff;
    background-color: rgba(0,150,255,0.08);
}

QTabBar::tab:selected {
    color: #e8f4ff;
    background-color: rgba(0,130,220,0.2);
    border-bottom: 2px solid #00cfff;
}

QPushButton {
    background-color: rgba(0,140,220,0.2);
    border: 1px solid rgba(0,160,255,0.35);
    border-radius: 3px;
    color: #c8e8ff;
    padding: 6px 16px;
    font-size: 12px;
}

QPushButton:hover {
    background-color: rgba(0,160,255,0.38);
    color: #e8f4ff;
    border-color: rgba(0,200,255,0.6);
}

QPushButton#shutdownButton {
    background-color: rgba(255,50,50,0.2);
    border-color: rgba(255,100,100,0.4);
}

QPushButton#shutdownButton:hover {
    background-color: rgba(255,70,70,0.38);
    border-color: rgba(255,150,150,0.6);
}

QTableWidget {
    background-color: rgba(8,24,48,0.92);
    border: 1px solid rgba(0,160,255,0.35);
    border-radius: 4px;
    gridline-color: rgba(0,140,220,0.12);
    selection-background-color: rgba(0,180,255,0.18);
