/* 全局样式 */
QWidget {
    background-color: #1a2035;
    color: #ffffff;
    font-family: Microsoft YaHei;
}

/* 主框架 */
QFrame#mainFrame {
    background-color: #2c354a;
    border-radius: 8px;
    padding: 8px;
}

/* 标题栏 */
QLabel#titleLabel {
    font-size: 9pt;
