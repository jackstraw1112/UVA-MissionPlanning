    background-color: #e74c3c;
    color: #ffffff;
    padding: 2px 8px;
    border-radius: 10px;
    font-size: 12px;
}

/* 参数标签 */
QLabel {
    color: #8892b0;
    font-size: 12px;
}

QLabel[name=&quot;typeValue&quot;],
QLabel[name=&quot;rangeValue&quot;],
QLabel[name=&quot;ammoValue&quot;],
