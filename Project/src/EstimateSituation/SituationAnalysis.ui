  <property name="styleSheet">
   <string notr="true">QMainWindow {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #0a0f1e, stop:1 #03060c);
    color: #eef2ff;
    font-family: 'Inter', 'Microsoft YaHei', sans-serif;
}

/* 卡片样式 */
QGroupBox {
    background: rgba(8, 16, 30, 190);
    border: 1px solid rgba(72, 187, 255, 77);
    border-radius: 16px;
    margin-top: 10px;
    padding-top: 10px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 12px 16px;
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgba(20, 40, 65, 230), stop:1 rgba(10, 22, 45, 180));
    color: #eef2ff;
    font-weight: 600;
    font-size: 1rem;
    border-bottom: 1px solid rgba(72, 187, 255, 77);
    border-top-left-radius: 16px;
    border-top-right-radius: 16px;
}

/* 表格样式 */
QTableWidget {
    background: rgba(12, 22, 40, 77);
    border: none;
    gridline-color: rgba(72, 120, 160, 51);
    selection-background-color: rgba(30, 70, 110, 102);
    font-size: 13px;
    border-bottom-left-radius: 16px;
    border-bottom-right-radius: 16px;
}

QTableWidget::item {
    padding: 10px 12px;
    border-bottom: 1px solid rgba(72, 120, 160, 51);
}

QTableWidget::item:selected {
    background-color: rgba(30, 70, 110, 153);
}

QTableWidget::item:hover {
    background-color: rgba(30, 70, 110, 102);
}

QHeaderView::section {
    background: rgba(12, 26, 45, 230);
    color: #c2e0ff;
    font-weight: 600;
    padding: 10px 12px;
    border-bottom: 1px solid rgba(72, 187, 255, 102);
    font-size: 12px;
}

/* 标签页样式 */
QTabWidget::pane {
    border: 1px solid rgba(72, 187, 255, 77);
    border-radius: 16px;
    background: rgba(8, 16, 30, 190);
}

QTabBar::tab {
    background: rgba(30, 50, 70, 128);
    color: #bbd9ff;
    padding: 8px 10px;
    margin: 6px 3px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 500;
}

QTabBar::tab:selected {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #2c577c, stop:1 #1a3a55);
    color: #fff;
    box-shadow: 0 2px 8px rgba(91, 192, 255, 77);
}

QTabBar::tab:hover {
    background: rgba(50, 80, 110, 153);
}

QTabBar::QToolButton {
    background: rgba(30, 50, 70, 130);
    color: #bbd9ff;
}

/* 按钮样式 */
QPushButton {
    background: rgba(30, 50, 70, 128);
    color: #bbd9ff;
    border: none;
    border-radius: 8px;
    padding: 8px 16px;
    font-size: 11px;
}

QPushButton:hover {
    background: rgba(50, 80, 110, 153);
}

QPushButton:pressed {
    background: rgba(20, 40, 60, 204);
}

/* 复选框样式 - 开关样式 */
QCheckBox {
    color: #eef2ff;
    font-size: 13px;
    spacing: 6px;
}

QCheckBox::indicator {
    width: 40px;
    height: 20px;
    border-radius: 10px;
    background: rgba(30, 50, 70, 204);
}

QCheckBox::indicator:unchecked {
    background: rgba(30, 50, 70, 204);
}

QCheckBox::indicator:checked {
    background: rgba(91, 192, 255, 128);
}

QCheckBox::indicator:checked:hover {
    background: rgba(91, 192, 255, 153);
}

QCheckBox::indicator::after {
    content: &quot;&quot;;
    position: absolute;
    width: 14px;
    height: 14px;
    left: 3px;
    bottom: 3px;
    background: #8E9CB9;
    border-radius: 50%;
    transition: 0.3s;
}

QCheckBox::indicator:checked::after {
    left: 23px;
    background: #5BC0FF;
}

/* 进度条样式 */
QProgressBar {
    border: none;
    background: rgba(0, 0, 0, 77);
    border-radius: 3px;
    text-align: center;
    color: #5BC0FF;
    font-weight: 500;
}

QProgressBar::chunk {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #5BC0FF, stop:1 #2E8B57);
    border-radius: 3px;
}

/* 标签样式 */
QLabel {
    color: #eef2ff;
    font-size: 12px;
}

QLabel[objectName^=&quot;stat&quot;] {
    font-size: 22px;
    font-weight: 700;
    color: #5BC0FF;
}

QLabel[objectName^=&quot;title&quot;] {
    font-size: 24px;
    font-weight: 600;
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #FFFFFF, stop:1 #80CFFF);
    color: transparent;
    background-clip: text;
}

/* 滚动条样式 */
QScrollBar:vertical {
    width: 6px;
    background: rgba(0, 0, 0, 51);
    border-radius: 3px;
}

QScrollBar::handle:vertical {
    background: rgba(91, 192, 255, 77);
    border-radius: 3px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background: rgba(91, 192, 255, 128);
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar:horizontal {
    height: 6px;
    background: rgba(0, 0, 0, 51);
    border-radius: 3px;
}

QScrollBar::handle:horizontal {
    background: rgba(91, 192, 255, 77);
    border-radius: 3px;
    min-width: 30px;
}

QScrollBar::handle:horizontal:hover {
    background: rgba(91, 192, 255, 128);
}

/* 分组标题样式 */
QWidget[objectName=&quot;headerWidget&quot;] {
    background: rgba(12, 20, 35, 204);
    border: 1px solid rgba(72, 187, 255, 77);
    border-radius: 16px;
}</string>
