    <property name="styleSheet">
      <string notr="true">QWidget#SituationControl {
  background-color: #0a0f1e;
}

/* 所有标签默认白色 */
QLabel {
  color: #ffffff;
}

/* 顶部标题栏 */
QWidget#titleWidget {
  background-color: rgba(12, 20, 35, 0.8);
  border-bottom: 1px solid rgba(72, 187, 255, 0.3);
}

QLabel#titleLabel {
  color: #ffffff;
  font-size: 16px;
  font-weight: 600;
}

QLabel#subtitleLabel {
  color: #ffffff;
  font-size: 12px;
}

/* 辐射源威力范围区域 */
QWidget#radiationGroup {
  background-color: rgba(8, 16, 30, 0.75);
}

QLabel#radiationTitle {
  color: #ffffff;
  font-size: 12px;
  font-weight: 500;
}

/* 列表项 */
QWidget#listItem {
  background-color: rgba(8, 16, 30, 0.75);
}

QLabel#itemName {
  color: #ffffff;
  font-size: 14px;
  font-weight: 500;
}

QLabel#itemIcon {
  color: #ffffff;
  font-size: 14px;
}

/* 开关按钮 */
QCheckBox {
  spacing: 0px;
}

/* 开关整体背景（深蓝色圆角条） */
QCheckBox::indicator {
  width: 40px;
  height: 20px;
  border-radius: 20px;
  background-color: rgba(30, 50, 70, 0.8);
  border: none;
}

/* 打开时背景变亮蓝色 */
QCheckBox::indicator:checked {
  background-color: rgba(91, 192, 255, 0.5);
}

/* 关闭时背景为深色 */
QCheckBox::indicator:unchecked {
  background-color: rgba(30, 50, 70, 0.8);
}

/* 滑块（圆形） */
QCheckBox::indicator::handle {
  border-radius: 7px;
  background-color: #8E9CB9;
  width: 14px;
  height: 14px;
  margin: 3px;
}

/* 未选中：滑块在左，灰白色 */
QCheckBox::indicator:unchecked::handle {
  x: 3px;
  background-color: #8E9CB9;
}

/* 选中：滑块在右，亮蓝色 */
QCheckBox::indicator:checked::handle {
  x: 23px;
  background-color: #5BC0FF;
}

/* 分隔线 */
QFrame#separator {
  background-color: rgba(72, 120, 160, 0.2);
  max-height: 1px;
}

/* 威力范围按钮 */
QPushButton#powerRangeButton {
  background-color: rgba(20, 40, 65, 0.6);
  color: #5BC0FF;
  border: 1px solid rgba(64, 128, 255, 0.3);
  border-radius: 20px;
  padding: 4px 12px;
  font-size: 11px;
  font-weight: 500;
}

QPushButton#powerRangeButton:hover {
  background-color: rgba(91, 192, 255, 0.1);
}
</string>
