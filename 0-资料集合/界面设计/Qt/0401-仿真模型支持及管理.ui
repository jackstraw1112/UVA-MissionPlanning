           <string>-- JWS-01 反辐射无人机行为脚本
function on_init()
    state = {mode = "SEARCH"}
    return true
end

function do_step(time, dt)
    -- 每帧执行逻辑
    return true
end

function on_finish()
    return true
end</string>
