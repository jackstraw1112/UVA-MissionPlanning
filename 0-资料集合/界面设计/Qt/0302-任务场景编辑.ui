<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MissionScenarioEditor</class>
 <widget class="QMainWindow" name="MissionScenarioEditor">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1200</width>
    <height>800</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>任务场景编辑 - 反辐射无人机仿真系统</string>
  </property>
  <widget class="QWidget" name="centralwidget">
   <layout class="QVBoxLayout" name="verticalLayout">
    <!-- 顶部工具栏 -->
    <item>
     <widget class="QToolBar" name="toolBar">
      <property name="iconSize">
       <size>
        <width>24</width>
        <height>24</height>
       </size>
      </property>
      <property name="toolButtonStyle">
       <enum>Qt::ToolButtonTextUnderIcon</enum>
      </property>
      <addaction name="actionNewScenario"/>
